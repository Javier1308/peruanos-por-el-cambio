# ─── Base de datos Supabase ────────────────────────────────────────────────────
# Obtener en: Supabase → Project Settings → Database → Connection string
#
# Opción A — Conexión directa (recomendada para Railway con 1 instancia):
#   postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Opción B — Connection Pooler Supavisor (si usas múltiples instancias):
#   postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# ─── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Obtener en: https://dash.cloudflare.com/ → Turnstile
# Clave de prueba (solo desarrollo): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=cambia-esto-en-produccion

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── API DNI (apis.net.pe) ────────────────────────────────────────────────────
DNI_API_URL=https://api.apis.net.pe/v2/reniec/dni
DNI_API_TOKEN=

# ─── Debug ────────────────────────────────────────────────────────────────────
DEBUG=false
