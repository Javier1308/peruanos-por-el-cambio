# Base de datos PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/peruanos

# Redis para rate limiting
REDIS_URL=redis://localhost:6379

# Cloudflare Turnstile — obtener en https://dash.cloudflare.com/
# Clave de prueba (funciona en desarrollo): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Clave de API para endpoints de administración
ADMIN_API_KEY=cambia-esto-en-produccion

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173

# API de consulta de DNI — https://apis.net.pe/
DNI_API_URL=https://api.apis.net.pe/v2/reniec/dni
DNI_API_TOKEN=

# Modo debug (false en producción)
DEBUG=false
